<Window x:Class="TicTacToe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicTacToe"
        mc:Ignorable="d"
        Icon="/app.ico"
        Title="Tic Tac Toe" Height="400" Width="300">
    <Grid x:Name="mainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>

        <Button x:Name="Square0" Tag="0" Grid.Column="0" Grid.Row="0" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>
        <Button x:Name="Square1" Tag="1" Grid.Column="1" Grid.Row="0" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>
        <Button x:Name="Square2" Tag="2" Grid.Column="2" Grid.Row="0" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>

        <Button x:Name="Square3" Tag="3" Grid.Column="0" Grid.Row="1" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>
        <Button x:Name="Square4" Tag="4" Grid.Column="1" Grid.Row="1" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>
        <Button x:Name="Square5" Tag="5" Grid.Column="2" Grid.Row="1" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>

        <Button x:Name="Square6" Tag="6" Grid.Column="0" Grid.Row="2" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>
        <Button x:Name="Square7" Tag="7" Grid.Column="1" Grid.Row="2" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>
        <Button x:Name="Square8" Tag="8" Grid.Column="2" Grid.Row="2" FontSize="48" Content=" " BorderThickness="0" Background="White" Click="Square_Clicked"/>

        <Button x:Name="NewGameButton" Grid.Row="5" Grid.ColumnSpan="2" Content="New Game" FontSize="30" BorderThickness="0" Background="White" Click="NewGame_Click"/>
        <Button x:Name="SettingsButton" Grid.Row="5" Grid.Column="2" FontSize="40" BorderThickness="0" Background="White" Click="Settings_Click" >
            <Image Source="/settings2.png" Width="50" Height="50"/>
        </Button>
        <TextBlock x:Name="PlayerText" Grid.Row="3" Grid.ColumnSpan="3" FontSize="24" HorizontalAlignment="Center" TextWrapping="Wrap" Text="You are playing Xs" VerticalAlignment="Center"/>
        
        <TextBlock x:Name="RecordText" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" FontSize="24" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Record: 0-0-0" VerticalAlignment="Center"/>
        
        <!-- Top row -->
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="Black" BorderThickness="0,0,4,4"/>
        <Border Grid.Row="0" Grid.Column="1" BorderBrush="Black" BorderThickness="4,0,4,4"/>
        <Border Grid.Row="0" Grid.Column="2" BorderBrush="Black" BorderThickness="4,0,0,4"/>

        <!-- Middle row -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="Black" BorderThickness="0,4,4,4"/>
        <Border Grid.Row="1" Grid.Column="1" BorderBrush="Black" BorderThickness="4,4,4,4"/>
        <Border Grid.Row="1" Grid.Column="2" BorderBrush="Black" BorderThickness="4,4,0,4"/>

        <!-- Bottom row -->
        <Border Grid.Row="2" Grid.Column="0" BorderBrush="Black" BorderThickness="0,4,4,0"/>
        <Border Grid.Row="2" Grid.Column="1" BorderBrush="Black" BorderThickness="4,4,4,0"/>
        <Border Grid.Row="2" Grid.Column="2" BorderBrush="Black" BorderThickness="4,4,0,0"/>
        
    </Grid>
</Window>
