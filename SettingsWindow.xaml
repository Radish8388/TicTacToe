<Window x:Class="TicTacToe.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicTacToe"
        mc:Ignorable="d"
        Icon="/settings1.png"
        Title="Settings" Height="175" Width="370">
    <Grid Margin="0,0,0,0">
        <TextBlock Text="Player" Margin="23,5,0,0"/>
        <RadioButton Name="Xs" Content="Play Xs" GroupName="Difficulty" IsChecked="True" HorizontalAlignment="Left" Margin="23,26,0,0" VerticalAlignment="Top"/>
        <RadioButton Name="Os" Content="Play Os" GroupName="Difficulty" HorizontalAlignment="Left" Margin="114,26,0,0" VerticalAlignment="Top"/>
        <RadioButton Name="Alternate" Content="Alternate Xs and Os" GroupName="Difficulty" HorizontalAlignment="Left" Margin="212,26,0,0" VerticalAlignment="Top"/>
        <TextBlock Text="Difficulty" Margin="23,55,0,0"/>
        <RadioButton Name="Easy" Content="Easy" GroupName="Token" IsChecked="True" HorizontalAlignment="Left" Margin="23,76,0,0" VerticalAlignment="Top"/>
        <RadioButton Name="Medium" Content="Medium" GroupName="Token" HorizontalAlignment="Left" Margin="114,76,0,0" VerticalAlignment="Top"/>
        <RadioButton Name="Hard" Content="Hard" GroupName="Token" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="212,76,0,0"/>
        <Button Name="okButton" Content="OK" IsDefault="True" HorizontalAlignment="Left" Margin="241,104,0,0" VerticalAlignment="Top" Click="okButton_Click" Width="50"/>
        <Button Name="cancelButton" Content="Cancel" IsCancel="True" HorizontalAlignment="Left" Margin="301,104,0,0" VerticalAlignment="Top" Click="cancelButton_Click" Width="50"/>

    </Grid>
</Window>
